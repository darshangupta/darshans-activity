# Vercel Postgres connection string
POSTGRES_URL=your-value-here

# Strava API app credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your-value-here
STRAVA_CLIENT_SECRET=your-value-here

# Redirect URI registered with your Strava API app, e.g. https://your-app.vercel.app/api/strava/callback
STRAVA_REDIRECT_URI=your-value-here

# Optional but recommended: secret used to authenticate Vercel Cron requests to /api/strava/sync.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-value-here
